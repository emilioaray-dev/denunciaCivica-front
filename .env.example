# ===========================================
# Denuncia Civica - Frontend Environment
# ===========================================
# Copy this file to .env.local and fill in values

# API Backend
# Use /api/v1 for local mock (Next.js route handlers)
# Use http://localhost:4000/api/v1 for NestJS backend
NEXT_PUBLIC_API_URL=/api/v1

# Auth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# CAPTCHA (hCaptcha or Cloudflare Turnstile)
NEXT_PUBLIC_CAPTCHA_SITE_KEY=

# App
NEXT_PUBLIC_APP_NAME=Denuncia Civica
NEXT_PUBLIC_APP_URL=http://localhost:3000
